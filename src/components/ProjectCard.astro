---
interface Props {
  href: string
  title: string
  description: string
  tags: string[]
  blogSlug?: string
  icon?: string
}

const { href, title, description, tags, blogSlug, icon } = Astro.props
---

<div class="p-6 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50 hover:border-zinc-400 dark:hover:border-zinc-500 transition-colors group">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      {icon && (
        <Fragment set:html={icon} />
      )}
      <h3 class="font-semibold text-zinc-900 dark:text-white">{title}</h3>
    </div>
  </div>
  <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-3">{description}</p>
  <div class="flex flex-wrap gap-1.5 mb-3">
    {tags.map((tag) => (
      <span class="px-2 py-0.5 text-xs rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">{tag}</span>
    ))}
  </div>
  {blogSlug && (
    <a
      href={`/blog/${blogSlug}`}
      class="text-xs text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1"
    >
      Read more
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>
  )}
</div>
