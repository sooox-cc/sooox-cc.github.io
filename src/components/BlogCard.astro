---
interface Props {
  slug: string
  title: string
  description: string
  date: Date
  tags: string[]
}

const { slug, title, description, date, tags } = Astro.props

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<a
  href={`/blog/${slug}`}
  class="p-6 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50 hover:border-zinc-400 dark:hover:border-zinc-500 transition-colors group block"
>
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-semibold text-zinc-900 dark:text-white group-hover:text-zinc-700 dark:group-hover:text-zinc-200 transition-colors">
      {title}
    </h3>
    <svg class="h-4 w-4 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors shrink-0 mt-0.5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
    </svg>
  </div>
  <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-3">{description}</p>
  <div class="flex items-center justify-between">
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="px-2 py-0.5 text-xs rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">{tag}</span>
      ))}
    </div>
    <span class="text-xs text-zinc-400 dark:text-zinc-500 shrink-0 ml-2">{formattedDate}</span>
  </div>
</a>
