---
import '../styles/global.css'
import { Font } from 'astro:assets'

interface Props {
  title: string
  description?: string
  ogType?: 'website' | 'article'
}

const { title, description, ogType = 'website' } = Astro.props
const canonicalUrl = Astro.url.href
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content="https://sooox.cc/og-image.png" />
    <meta property="og:site_name" content="sooox.cc" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content="https://sooox.cc/og-image.png" />

    <Font cssVariable="--font-fira-code" preload />
  </head>
  <body class="min-h-screen bg-white dark:bg-zinc-800">
    <div class="flex min-h-screen flex-col">
      <slot />
    </div>
  </body>
</html>
