---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      @font-face {
        font-family: 'Gohufont';
        src: local('GohuFont'), url('/fonts/GohuFont-Medium.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: 'Gohufont';
        src: local('GohuFont'), url('/fonts/GohuFont-Bold.ttf') format('truetype');
        font-weight: 700;
        font-style: normal;
      }
      * {
        font-family: 'Gohufont', monospace;
      }
    </style>
  </head>
  <body class="min-h-screen bg-white dark:bg-zinc-800">
    <div class="flex min-h-screen flex-col">
      <slot />
    </div>
  </body>
</html>
