---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ProjectCard from '../components/ProjectCard.astro'
---

<Layout title="sooox.cc">
  <Header />

  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-6 py-12 lg:py-20">

      <!-- Hero / About -->
      <section id="about" class="mb-20">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-block mb-6">
            <div class="px-3 py-1.5 rounded-full border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-900">
              <div class="flex items-center gap-2">
                <div class="h-2 w-2 rounded-full bg-green-500 pulse-dot"></div>
                <span class="text-xs font-medium text-zinc-600 dark:text-zinc-400">Last updated: 11/03</span>
              </div>
            </div>
          </div>

          <h1 class="text-5xl md:text-6xl font-bold text-zinc-900 dark:text-white mb-6 leading-tight">
            sooox
          </h1>

          <p class="text-lg text-zinc-600 dark:text-zinc-300 mb-2">
            MSc Cybersecurity student. Privacy advocate. Arch Linux btw.
          </p>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-12 font-mono">
            cybersecurity &middot; machine learning &middot; full-stack dev &middot; self-hosting
          </p>

          <!-- Quick Stats -->
          <div class="grid grid-cols-3 gap-4 max-w-md mx-auto mb-12">
            <div>
              <div class="text-2xl font-bold text-zinc-900 dark:text-white">12</div>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Languages</p>
            </div>
            <div>
              <div class="text-2xl font-bold text-zinc-900 dark:text-white">6+</div>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Frameworks</p>
            </div>
            <div>
              <div class="text-2xl font-bold text-zinc-900 dark:text-white">5+</div>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Databases</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Current Project -->
      <section id="project" class="pt-20 mb-20">
        <h2 class="text-3xl font-bold text-zinc-900 dark:text-white mb-12 text-center">Current Work</h2>

        <div class="p-6 rounded-lg border border-green-200 dark:border-green-900/30 bg-green-50 dark:bg-green-950/20 max-w-3xl mx-auto">
          <div class="flex items-start gap-4">
            <div class="mt-1 shrink-0">
              <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-semibold text-green-900 dark:text-green-100">Master's Thesis</h3>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-200 dark:bg-green-900/50 text-green-800 dark:text-green-300">Active</span>
              </div>
              <p class="text-sm text-green-800 dark:text-green-200 mb-3">
                Comparative analysis of machine learning models for threat detection in resource-constrained environments.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">TensorFlow</span>
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">PyTorch</span>
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">scikit-learn</span>
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">Embedded C++</span>
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">PlatformIO</span>
                <span class="px-2 py-1 text-xs rounded border border-green-300 dark:border-green-800 text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/30">Jupyter</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Skills -->
      <section id="skills" class="mb-20">
        <h2 class="text-3xl font-bold text-zinc-900 dark:text-white mb-12 text-center">Skills & Technologies</h2>

        <!-- Languages -->
        <div class="mb-8">
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
            Languages
          </h3>
          <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
            {[
              { src: "/icons/python-light.svg", name: "Python" },
              { src: "/icons/php-light.svg", name: "PHP" },
              { src: "/icons/javascript.svg", name: "JavaScript" },
              { src: "/icons/java-light.svg", name: "Java" },
              { src: "/icons/c.svg", name: "C" },
              { src: "/icons/cpp.svg", name: "C++" },
              { src: "/icons/cs.svg", name: "C#" },
              { src: "/icons/bash-light.svg", name: "Bash" },
              { src: "/icons/html.svg", name: "HTML" },
              { src: "/icons/css.svg", name: "CSS" },
              { src: "/icons/rust.svg", name: "Rust" },
              { src: "/icons/typescript.svg", name: "TypeScript" },
            ].map(({ src, name }) => (
              <div class="p-4 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50 text-center flex flex-col items-center gap-2">
                <img src={src} alt={name} class="tech-icon" />
                <span class="text-xs font-medium text-zinc-900 dark:text-white">{name}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Web Development -->
        <div class="mb-8">
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
            Web Development
          </h3>

          <div class="grid md:grid-cols-2 gap-4">
            <!-- Backend -->
            <div class="p-5 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50">
              <h4 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-3 uppercase tracking-wider">Backend</h4>
              <div class="grid grid-cols-3 gap-3">
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/laravel-light.svg" alt="Laravel" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Laravel</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/flask-light.svg" alt="Flask" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Flask</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/nodejs-light.svg" alt="Node.js" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Node.js</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/spring-light.svg" alt="Spring" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Spring</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/dotnet.svg" alt="ASP.NET" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">ASP.NET</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <svg class="tech-icon" xmlns="http://www.w3.org/2000/svg" width="128" height="128" viewBox="0 0 128 128"><path style="fill-rule:evenodd;fill:#fb70a9;fill-opacity:1" d="M108.566 83.547c-1.937 2.926-3.406 6.527-7.34 6.527-6.624 0-6.98-10.203-13.609-10.203-6.625 0-6.265 10.203-12.887 10.203-6.625 0-6.98-10.203-13.609-10.203-6.625 0-6.266 10.203-12.887 10.203-6.625 0-6.98-10.203-13.605-10.203-6.629 0-6.27 10.203-12.89 10.203-2.083 0-3.544-1.008-4.778-2.39-4.738-8.239-7.465-17.895-7.465-28.22 0-30.222 23.367-54.722 52.191-54.722 28.825 0 52.192 24.5 52.192 54.723 0 8.64-1.91 16.816-5.313 24.082Zm0 0"/><path style="fill-rule:evenodd;fill:#4e56a6;fill-opacity:1" d="M40.844 78.145v22.668c0 4.066-3.301 7.363-7.371 7.363a7.365 7.365 0 0 1-7.371-7.364V73.45c1.375-2.523 2.945-4.707 5.78-4.707 4.61 0 6.223 5.79 8.962 9.403Zm27.843 1.183v35.844a8.185 8.185 0 0 1-8.187 8.183c-4.523 0-8.191-3.664-8.191-8.183v-40.57c1.543-2.973 3.132-5.86 6.39-5.86 5.16 0 6.563 7.242 9.989 10.586Zm26.211-.66v26.023c0 4.067-3.3 7.364-7.37 7.364-4.071 0-7.372-3.297-7.372-7.364V72.707c1.281-2.195 2.809-3.965 5.364-3.965 4.84 0 6.375 6.38 9.378 9.926Zm0 0"/></svg>
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Livewire</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/tauri-light.svg" alt="Tauri" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Tauri</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/elasticsearch-light.svg" alt="Elasticsearch" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Elasticsearch</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/streamlit.svg" alt="Streamlit" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Streamlit</span>
                </div>
              </div>
            </div>

            <!-- Frontend -->
            <div class="p-5 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50">
              <h4 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-3 uppercase tracking-wider">Frontend</h4>
              <div class="grid grid-cols-3 gap-3">
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/tailwindcss-light.svg" alt="Tailwind CSS" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Tailwind</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/alpinejs-light.svg" alt="Alpine.js" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Alpine.js</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/jquery.svg" alt="jQuery" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">jQuery</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/bootstrap.svg" alt="Bootstrap" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Bootstrap</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/thymeleaf.svg" alt="Thymeleaf" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Thymeleaf</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/html.svg" alt="Blade" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">Blade</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/react-light.svg" alt="React" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">React</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="data:image/svg+xml;base64," alt="EJS" class="tech-icon rounded">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">EJS</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Data & AI/ML -->
        <div class="mb-8">
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            Data & AI/ML
          </h3>

          <div class="grid md:grid-cols-2 gap-4">
            <!-- AI/ML -->
            <div class="p-5 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50">
              <h4 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-3 uppercase tracking-wider">AI / Machine Learning</h4>
              <div class="grid grid-cols-3 gap-3">
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/tensorflow-light.svg" alt="TensorFlow" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">TensorFlow</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/pytorch-light.svg" alt="PyTorch" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">PyTorch</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/opencv-light.svg" alt="OpenCV" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">OpenCV</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/scikitlearn-light.svg" alt="scikit-learn" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">scikit-learn</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/ultralytics.svg" alt="YOLOv8" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">YOLOv8</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
                  <img src="/icons/pandas.svg" alt="pandas" class="tech-icon">
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">pandas</span>
                </div>
              </div>
            </div>

            <!-- Data Engineering -->
            <div class="p-5 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50">
              <h4 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-3 uppercase tracking-wider">Data Engineering</h4>
              <div class="grid grid-cols-3 gap-3">
                <div class="flex flex-col items-center gap-2 p-2">
                  <svg class="tech-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48"><path fill="url(#fabric-a)" fill-rule="evenodd" d="m5.64 31.6-.586 2.144c-.218.685-.524 1.693-.689 2.59a5.629 5.629 0 0 0 4.638 7.588c.792.114 1.688.108 2.692-.04l4.613-.636a2.924 2.924 0 0 0 2.421-2.127l3.175-11.662L5.64 31.599Z" clip-rule="evenodd"/><path fill="url(#fabric-b)" d="M10.14 32.152c-4.863.753-5.861 4.423-5.861 4.423l4.656-17.11 24.333-3.292-3.318 12.052a1.706 1.706 0 0 1-1.388 1.244l-.136.022-18.423 2.684.137-.023Z"/><path fill="url(#fabric-c)" fill-opacity=".8" d="M10.14 32.152c-4.863.753-5.861 4.423-5.861 4.423l4.656-17.11 24.333-3.292-3.318 12.052a1.706 1.706 0 0 1-1.388 1.244l-.136.022-18.423 2.684.137-.023Z"/><path fill="url(#fabric-d)" d="m12.899 21.235 26.938-3.98a1.597 1.597 0 0 0 1.323-1.17l2.78-10.06a1.595 1.595 0 0 0-1.74-2.012L16.498 7.81a7.185 7.185 0 0 0-5.777 5.193L7.013 26.438c.744-2.717 1.202-4.355 5.886-5.203Z"/><path fill="url(#fabric-e)" d="m12.899 21.235 26.938-3.98a1.597 1.597 0 0 0 1.323-1.17l2.78-10.06a1.595 1.595 0 0 0-1.74-2.012L16.498 7.81a7.185 7.185 0 0 0-5.777 5.193L7.013 26.438c.744-2.717 1.202-4.355 5.886-5.203Z"/><path fill="url(#fabric-f)" fill-opacity=".4" d="m12.899 21.235 26.938-3.98a1.597 1.597 0 0 0 1.323-1.17l2.78-10.06a1.595 1.595 0 0 0-1.74-2.012L16.498 7.81a7.185 7.185 0 0 0-5.777 5.193L7.013 26.438c.744-2.717 1.202-4.355 5.886-5.203Z"/><path fill="url(#fabric-g)" d="M12.899 21.236c-3.901.706-4.87 1.962-5.514 3.932L4.279 36.577s.992-3.633 5.796-4.41l18.352-2.673.136-.022a1.707 1.707 0 0 0 1.388-1.244l2.73-9.915-19.782 2.923Z"/><path fill="url(#fabric-h)" fill-opacity=".2" d="M12.899 21.236c-3.901.706-4.87 1.962-5.514 3.932L4.279 36.577s.992-3.633 5.796-4.41l18.352-2.673.136-.022a1.707 1.707 0 0 0 1.388-1.244l2.73-9.915-19.782 2.923Z"/><path fill="url(#fabric-i)" fill-rule="evenodd" d="M10.075 32.167c-4.06.657-5.392 3.345-5.71 4.164a5.629 5.629 0 0 0 4.638 7.59c.792.114 1.688.108 2.692-.039l4.613-.637a2.924 2.924 0 0 0 2.421-2.127l2.894-10.633-11.547 1.683-.001-.001Z" clip-rule="evenodd"/><defs><linearGradient id="fabric-a" x1="12.953" x2="12.953" y1="44.001" y2="29.457" gradientUnits="userSpaceOnUse"><stop offset=".056" stop-color="#2AAC94"/><stop offset="1" stop-color="#085954"/></linearGradient><linearGradient id="fabric-b" x1="31.331" x2="17.286" y1="33.448" y2="18.173" gradientUnits="userSpaceOnUse"><stop offset=".042" stop-color="#ABE88E"/><stop offset=".549" stop-color="#2AAA92"/><stop offset=".906" stop-color="#117865"/></linearGradient><linearGradient id="fabric-c" x1="-3.182" x2="10.183" y1="32.706" y2="28.148" gradientUnits="userSpaceOnUse"><stop stop-color="#6AD6F9"/><stop offset="1" stop-color="#6AD6F9" stop-opacity="0"/></linearGradient><linearGradient id="fabric-d" x1="7.013" x2="42.589" y1="15.219" y2="15.219" gradientUnits="userSpaceOnUse"><stop offset=".043" stop-color="#25FFD4"/><stop offset=".874" stop-color="#55DDB9"/></linearGradient><linearGradient id="fabric-e" x1="7.013" x2="39.06" y1="10.247" y2="25.128" gradientUnits="userSpaceOnUse"><stop stop-color="#6AD6F9"/><stop offset=".651" stop-color="#6DE9BB"/><stop offset=".994" stop-color="#ABE88E"/></linearGradient><linearGradient id="fabric-f" x1="9.978" x2="27.404" y1="13.031" y2="16.885" gradientUnits="userSpaceOnUse"><stop stop-color="#fff" stop-opacity="0"/><stop offset=".459" stop-color="#fff"/><stop offset="1" stop-color="#fff" stop-opacity="0"/></linearGradient><linearGradient id="fabric-g" x1="15.756" x2="16.168" y1="27.96" y2="15.74" gradientUnits="userSpaceOnUse"><stop offset=".205" stop-color="#063D3B" stop-opacity="0"/><stop offset=".872" stop-color="#063D3B" stop-opacity=".75"/></linearGradient><linearGradient id="fabric-h" x1="2.81" x2="17.701" y1="26.744" y2="29.545" gradientUnits="userSpaceOnUse"><stop stop-color="#fff" stop-opacity="0"/><stop offset=".459" stop-color="#fff"/><stop offset="1" stop-color="#fff" stop-opacity="0"/></linearGradient><linearGradient id="fabric-i" x1="13.567" x2="10.662" y1="39.97" y2="25.764" gradientUnits="userSpaceOnUse"><stop offset=".064" stop-color="#063D3B" stop-opacity="0"/><stop offset="1" stop-color="#063D3B"/></linearGradient></defs></svg>
                  <span class="text-xs text-zinc-700 dark:text-zinc-300">MS Fabric</span>
                </div>
                <div class="flex flex-col items-center gap-2 p-2">
